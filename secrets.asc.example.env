# App Store Connect / TestFlight credentials (gitignored)
# Copy to secrets.asc.env and fill in.
#
# API Key ID from App Store Connect → Users and Access → Integrations → App Store Connect API
# (10-character id, e.g. 725F75L52R)
ASC_KEY_ID=725F75L52R
#
# Issuer ID (UUID) from the same Integrations page
ASC_ISSUER_ID=
#
# Path to the downloaded AuthKey_<KEY_ID>.p8 file
ASC_KEY_PATH=
#
# Optional: numeric App Store Connect Apple ID for the app (App Information page)
ASC_APP_APPLE_ID=
